<section class="products-hero">
    <div class="products-hero__wrapper">
        <div class="products-hero__img-wrapper">
            <div class="products-hero__img-gradient">

            </div>
            <img class="products-hero__img" src="./img/products/hero/products-hero.webp" />
        </div>
        <div class="products-hero__content">
            <h2 class="products-hero__headline">Shoping without limits.</h2>
            <p class="products-hero__phrase">You can choose the best option for you, and it does not matter whether you are in Prague or San Francisco. We will deliver your purchase anywhere!</p>

            {{> components/order-btn 
            order-btn-class="products-hero__order-btn" 
            order-btn-linkTo="shop" 
            order-btn-text="SHOP NOW"
            }}
        </div>
    </div>
</section>